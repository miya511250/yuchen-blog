---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { profile } from '../data/profile';
---

<!doctype html>
<html lang={profile.language}>
	<head>
		<BaseHead title={`关于 - ${SITE_TITLE}`} description={`${profile.author} 的个人介绍。`} />
	</head>
	<body>
		<Header />
		<main class="about-page">
			<section class="page-heading">
				<p class="eyebrow">About</p>
				<h1>关于 {profile.author}</h1>
				<p>{profile.bio}</p>
			</section>

			<section class="about-grid" aria-label="个人信息">
				<div>
					<h2>我会记录什么</h2>
					<p>
						这里会放下关于前端、AI 和生活的阶段性思考。它不追求一次写完所有答案，更像是一份持续整理的个人笔记。
					</p>
				</div>
				<div>
					<h2>联系我</h2>
					<ul class="link-list">
						<li><a href={`https://github.com/${profile.github}`}>GitHub: {profile.github}</a></li>
						<li><a href={`mailto:${profile.email}`}>{profile.email}</a></li>
					</ul>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
