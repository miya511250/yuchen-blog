---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { profile } from '../data/profile';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const tagMap = posts.reduce<Record<string, number>>((acc, post) => {
	for (const tag of post.data.tags) {
		acc[tag] = (acc[tag] ?? 0) + 1;
	}
	return acc;
}, {});

const tags = Object.entries(tagMap).sort((a, b) => a[0].localeCompare(b[0], 'zh-CN'));
---

<!doctype html>
<html lang={profile.language}>
	<head>
		<BaseHead title={`标签 - ${SITE_TITLE}`} description="按标签浏览 YuchenBlog 的文章。" />
	</head>
	<body>
		<Header />
		<main class="tags-page">
			<header class="page-heading">
				<p class="eyebrow">Tags</p>
				<h1>标签</h1>
				<p>从关键词开始，回到相关的文章和想法。</p>
			</header>
			<section class="tag-cloud" aria-label="标签列表">
				{
					tags.map(([tag, count]) => (
						<a href={`/tags/${encodeURIComponent(tag)}/`}>
							<span>{tag}</span>
							<small>{count}</small>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
